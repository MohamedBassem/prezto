#
# Executes commands at the start of an interactive session.
#
# Authors:
#   Sorin Ionescu <sorin.ionescu@gmail.com>
#

# Homebrew defaults
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_ENV_HINTS=1
export HOMEBREW_NO_INSECURE_REDIRECT=1
export HOMEBREW_NO_AUTO_UPDATE=1
export HOMEBREW_CASK_OPTS="--require-sha"

# Make Homebrew tools visible before Prezto modules run.
if [[ "$OSTYPE" == darwin* && -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# brew shellenv above re-prepends /opt/homebrew, which would shadow the
# volta/bun node toolchains that .zprofile placed ahead of it. Re-assert their
# precedence so volta-managed node keeps winning (also covers non-login shells,
# where .zprofile does not run). (N) drops the entries if the dirs are absent.
path=($HOME/.volta/bin(N) $HOME/.bun/bin(N) $path)

# Prefer a Homebrew-managed ssh-agent over macOS's launchd socket.
if [[ "$OSTYPE" == darwin* && "$SSH_AUTH_SOCK" == /var/run/com.apple.launchd.* ]]; then
  unset SSH_AUTH_SOCK
fi

# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

[ -f "/usr/facebook/ops/rc/master.zshrc" ] && source "/usr/facebook/ops/rc/master.zshrc"

# Customize to your needs...

# ls: prefer eza when installed, otherwise fall back per-OS
if [ -x "$(command -v eza)" ]; then
  alias ls='eza'
  alias ll='eza -la --git'
elif [[ "$OSTYPE" == "darwin"* ]]; then
  alias ls='ls -GF'
  alias ll='ls -alhFG'
else
  alias ls='ls -F --color=auto'
  alias ll='ls -alhF'
fi
# Map vim to nvim
alias vim="nvim"
alias vi="nvim"

# Print the nth column
function awkp() {
  awk "{print \$$1}"
}

# custom Vars
export EDITOR=nvim
export HGEDITOR=nvim

# Tool homes (env vars only; PATH entries are consolidated in .zprofile)
export GOPATH=~/repos/go
export BUN_INSTALL="$HOME/.bun"
export VOLTA_HOME="$HOME/.volta"

# Java / Android (Android Studio bundled JDK). Global env so java tooling works
# everywhere; guarded with [[ -d ]] so machines without Android Studio/the SDK
# are unaffected. (N) drops PATH entries whose dir is missing.
if [[ -d "/Applications/Android Studio.app/Contents/jbr/Contents/Home" ]]; then
  export JAVA_HOME="/Applications/Android Studio.app/Contents/jbr/Contents/Home"
  path=($JAVA_HOME/bin(N) $path)
fi
if [[ -d "$HOME/Library/Android/sdk" ]]; then
  export ANDROID_HOME="$HOME/Library/Android/sdk"
  path=($ANDROID_HOME/platform-tools(N) $ANDROID_HOME/emulator(N) $path)
fi

# cargo (its env script sets PATH itself)
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# nvm (lazy-loaded; previously sourced with --no-use, so no node was on PATH
# at startup anyway — this just defers parsing nvm.sh until first use)
export NVM_DIR="$HOME/.nvm"
nvm() {
  unset -f nvm
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  nvm "$@"
}

# fzf (before atuin so atuin's Ctrl-R binding wins)
if [ -x "$(command -v fzf)" ]; then
  source <(fzf --zsh)
  export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
fi

# atuin
[ -x "$(command -v atuin)" ] && eval "$(atuin init zsh --disable-up-arrow)"

# zoxide
[ -x "$(command -v zoxide)" ] && eval "$(zoxide init zsh)"

# brew
[ -f /home/linuxbrew/.linuxbrew/bin/brew ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# direnv
[ -x "$(command -v direnv)" ] && eval "$(direnv hook zsh)"

# eza
export EZA_ICONS_AUTO=1

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/mbassem/repos/google-cloud-sdk/path.zsh.inc' ]; then . '/Users/mbassem/repos/google-cloud-sdk/path.zsh.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/mbassem/repos/google-cloud-sdk/completion.zsh.inc' ]; then . '/Users/mbassem/repos/google-cloud-sdk/completion.zsh.inc'; fi
